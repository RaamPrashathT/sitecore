datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

enum Role {
    IDLE
    ADMIN
    ENGINEER
    CLIENT
}

enum CatalogueCategory {
    MATERIALS
    LABOUR
    EQUIPMENT
    SUBCONTRACTORS
    TRANSPORT
    OVERHEAD
}

enum PhaseStatus {
    PLANNING
    PAYMENT_PENDING
    ACTIVE
    COMPLETED
}

enum RequisitionStatus {
    DRAFT
    PENDING_APPROVAL
    APPROVED
    REJECTED
}

enum RequisitionItemStatus {
    ORDERED
    UNORDERED
}

model Organization {
    id        String   @id @default(uuid())
    name      String
    slug      String   @unique
    slugBase  String
    slugIndex Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    image     String?

    catalogue Catalogue[]
    members   Membership[]
    projects  Project[]
}

model Membership {
    id     String @id @default(uuid())
    userId String
    role   Role

    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId String

    @@unique([userId, organizationId])
}

model Catalogue {
    id              String            @id @default(uuid())
    name            String
    category        CatalogueCategory
    unit            String
    defaultLeadTime Int               @default(0)

    supplierQuotes SupplierQuote[]

    organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId   String
    requisitionItems RequisitionItem[]

    @@unique([name, organizationId])
}

model SupplierQuote {
    id           String  @id @default(uuid())
    supplier     String
    truePrice    Decimal
    standardRate Decimal
    leadTime     Int?

    catalogue    Catalogue         @relation(fields: [catalogueId], references: [id], onDelete: Cascade)
    catalogueId  String
    assignedItem RequisitionItem[]

    @@unique([catalogueId, supplier])
}

model Project {
    id              String  @id @default(uuid())
    name            String
    slug            String
    slugBase        String
    slugIndex       Int
    address         String
    estimatedBudget Decimal

    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId String

    assignments Assignment[]
    phases      Phase[]

    @@unique([slug, organizationId])
}

model Assignment {
    id     String @id @default(uuid())
    userId String
    role   Role

    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId String

    @@unique([userId, projectId])
}

model Phase {
    id              String      @id @default(uuid())
    name            String
    description     String?
    budget          Decimal
    paymentDeadline DateTime
    startDate       DateTime
    isPaid          Boolean     @default(false)
    status          PhaseStatus @default(PLANNING)
    projectId       String
    project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

    requisitions Requisition[]
    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt

    @@unique([name, projectId])
}

model Requisition {
    id          String            @id @default(uuid())
    status      RequisitionStatus @default(DRAFT)
    phaseId     String
    phase       Phase             @relation(fields: [phaseId], references: [id], onDelete: Cascade)
    requestedBy String
    budget      Decimal

    items     RequisitionItem[]
    createdAt DateTime          @default(now())
    updatedAt DateTime          @updatedAt
}

model RequisitionItem {
    id                String                @id @default(uuid())
    quantity          Decimal
    estimatedUnitCost Decimal
    status            RequisitionItemStatus @default(UNORDERED)

    catalogueId String
    catalogue   Catalogue @relation(fields: [catalogueId], references: [id], onDelete: Cascade)

    assignedSupplierId String?
    assignedSupplier   SupplierQuote? @relation(fields: [assignedSupplierId], references: [id], onDelete: Cascade)

    requisitionId String
    requisition   Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
}
