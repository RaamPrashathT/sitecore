datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

enum Role {
    ADMIN
    ENGINEER
    USER
}

enum CatalogueCategory {
    MATERIALS
    LABOUR
    EQUIPMENT
    SUBCONTRACTORS
    TRANSPORT
    OVERHEAD
}

model Organization {
    id        String   @id @default(uuid())
    orgName   String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    image     String?

    catalogue Catalogue[]
    members   Membership[]
    projects  Project[]
}

model Membership {
    id     String @id @default(uuid())
    userId String
    role   Role

    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId String

    @@unique([userId, organizationId])
}

model Catalogue {
    id              String            @id @default(uuid())
    name            String
    category        CatalogueCategory
    unit            String
    defaultLeadTime Int               @default(0)

    supplierQuotes SupplierQuote[]

    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId String
}

model SupplierQuote {
    id           String  @id @default(uuid())
    supplier     String
    truePrice    Decimal
    standardRate Decimal
    leadTime     Int?

    catalogue   Catalogue @relation(fields: [catalogueId], references: [id], onDelete: Cascade)
    catalogueId String
}

model Project {
    id   String @id @default(uuid())
    name String

    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId String

    assignments Assignment[]
}

model Assignment {
    id     String @id @default(uuid())
    userId String

    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId String

    @@unique([userId, projectId])
}
