datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

enum Role {
    IDLE
    ADMIN
    ENGINEER
    CLIENT
}

enum InvitationStatus {
    PENDING
    ACCEPTED
    REJECTED
}

enum CatalogueCategory {
    MATERIALS
    LABOUR
    EQUIPMENT
    SUBCONTRACTORS
    TRANSPORT
    OVERHEAD
}

enum ProjectStatus {
    DRAFT
    ACTIVE
    COMPLETED
    ARCHIVED
}

enum PhaseStatus {
    PLANNING
    PAYMENT_PENDING
    ACTIVE
    COMPLETED
}

enum RequisitionStatus {
    DRAFT
    PENDING_APPROVAL
    APPROVED
    REJECTED
}

enum RequisitionItemStatus {
    ORDERED
    UNORDERED
}

enum NotificationType {
    REQUISITION_SUBMITTED
    REQUISITION_APPROVED
    REQUISITION_REJECTED
    PHASE_STATUS_CHANGED
    PHASE_PAYMENT_DUE
    SITE_LOG_CREATED
    PROJECT_STATUS_CHANGED
    PROJECT_INVITATION_ACCEPTED
    PROJECT_INVITATION_REJECTED
    ORGANIZATION_INVITATION_REQUEST
}

enum NotificationEntityType {
    REQUISITION
    PHASE
    SITE_LOG
    PROJECT
    INVITATION
}

enum MeasurementUnit {
    NOS
    BAG
    ROLL
    BUNDLE
    SET
    PAIR
    KG
    MT
    QUINTAL
    CUM
    CFT
    LITRE
    SQM
    SQFT
    RMT
    RFT
    DAY
    HOUR
    MONTH
    TRIP
    LS
}

enum TransactionType {
    RECEIVED
    CONSUMED
    ADJUSTED
}

// --- CORE MODELS ---

model Organization {
    id        String   @id @default(uuid())
    name      String
    slug      String   @unique
    slugBase  String
    slugIndex Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    image     String?

    notifications      Notification[]
    catalogue          Catalogue[]
    members            Membership[]
    projects           Project[]
    suppliers          Supplier[]
    inventoryLocations InventoryLocation[]
}

model Membership {
    id     String @id @default(uuid())
    userId String
    role   Role

    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId String

    siteLogs               SiteLog[]
    images                 Image[]
    comments               Comment[]
    notificationRecipients NotificationRecipient[]
    inventoryLogs          InventoryTransaction[]

    @@unique([userId, organizationId])
}

// --- PROCUREMENT & CATALOGUE ---

model Supplier {
    id          String  @id @default(uuid())
    name        String
    contactName String?
    email       String?
    phone       String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    organizationId String
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    quotes SupplierQuote[]

    @@unique([name, organizationId])
}

model Catalogue {
    id              String            @id @default(uuid())
    name            String
    category        CatalogueCategory
    unit            MeasurementUnit
    defaultLeadTime Int               @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    organizationId String
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    supplierQuotes   SupplierQuote[]
    inventoryItems   InventoryItem[]
    requisitionItems RequisitionItem[]

    @@unique([name, organizationId])
}

model SupplierQuote {
    id           String    @id @default(uuid())
    truePrice    Decimal
    standardRate Decimal
    leadTimeDays Int?
    validUntil   DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    supplierId String
    supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

    catalogueId String
    catalogue   Catalogue @relation(fields: [catalogueId], references: [id], onDelete: Cascade)

    assignedItem RequisitionItem[]

    @@unique([catalogueId, supplierId])
}

// --- INVENTORY MANAGEMENT ---

model InventoryLocation {
    id   String @id @default(uuid())
    name String
    type String

    organizationId String
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    items InventoryItem[]

    @@unique([name, organizationId])
}

model InventoryItem {
    id              String  @id @default(uuid())
    quantityOnHand  Decimal @default(0)
    averageUnitCost Decimal @default(0)

    locationId String
    location   InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

    catalogueId String
    catalogue   Catalogue @relation(fields: [catalogueId], references: [id], onDelete: Cascade)

    transactions InventoryTransaction[]

    @@unique([locationId, catalogueId])
}

model InventoryTransaction {
    id             String          @id @default(uuid())
    quantityChange Decimal
    type           TransactionType
    notes          String?

    createdAt DateTime @default(now())

    recordedById String
    recordedBy   Membership @relation(fields: [recordedById], references: [id])

    inventoryItemId String
    inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

    phaseId String?
    phase   Phase?  @relation(fields: [phaseId], references: [id])
}

// --- PROJECT EXECUTION ---

model Project {
    id              String        @id @default(uuid())
    name            String
    slug            String
    slugBase        String
    slugIndex       Int
    address         String
    estimatedBudget Decimal
    status          ProjectStatus @default(ACTIVE)

    organizationId String
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    assignments   Assignment[]
    phases        Phase[]
    invitations   InvitationProject[]
    notifications Notification[]

    @@unique([slug, organizationId])
}

model Assignment {
    id     String @id @default(uuid())
    userId String
    role   Role

    projectId String
    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@unique([userId, projectId])
}

model Phase {
    id              String      @id @default(uuid())
    name            String
    slug            String
    slugBase        String
    slugIndex       Int
    description     String?
    budget          Decimal
    paymentDeadline DateTime
    startDate       DateTime
    isPaid          Boolean     @default(false)
    status          PhaseStatus @default(PLANNING)
    sequenceOrder   Decimal     @default(1.0)

    projectId String
    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    requisitions  Requisition[]
    siteLogs      SiteLog[]
    inventoryUsed InventoryTransaction[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([slug, projectId])
}

model SiteLog {
    id          String  @id @default(uuid())
    title       String
    description String?

    phaseId String
    phase   Phase  @relation(fields: [phaseId], references: [id], onDelete: Cascade)

    authorId String
    author   Membership @relation(fields: [authorId], references: [id])

    images   Image[]
    comments Comment[]

    workDate  DateTime
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Image {
    id  String @id @default(uuid())
    url String

    uploaderId String
    uploader   Membership @relation(fields: [uploaderId], references: [id])

    siteLogId String
    siteLog   SiteLog @relation(fields: [siteLogId], references: [id], onDelete: Cascade)

    comments Comment[]

    createdAt DateTime @default(now())
}

model Comment {
    id   String @id @default(uuid())
    text String

    authorId String
    author   Membership @relation(fields: [authorId], references: [id])

    sitelogId String
    sitelog   SiteLog @relation(fields: [sitelogId], references: [id], onDelete: Cascade)

    imageId String?
    image   Image?  @relation(fields: [imageId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Requisition {
    id          String            @id @default(uuid())
    title       String
    slug        String
    slugBase    String
    slugIndex   Int
    status      RequisitionStatus @default(DRAFT)
    budget      Decimal
    requestedBy String

    phaseId String
    phase   Phase  @relation(fields: [phaseId], references: [id], onDelete: Cascade)

    items RequisitionItem[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([slug, phaseId])
}

model RequisitionItem {
    id                String                @id @default(uuid())
    quantity          Decimal
    estimatedUnitCost Decimal
    status            RequisitionItemStatus @default(UNORDERED)

    catalogueId String
    catalogue   Catalogue @relation(fields: [catalogueId], references: [id], onDelete: Cascade)

    assignedSupplierId String?
    assignedSupplier   SupplierQuote? @relation(fields: [assignedSupplierId], references: [id], onDelete: Cascade)

    requisitionId String
    requisition   Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
}

// --- UTILITIES & NOTIFICATIONS ---

model Invitation {
    id        String   @id @default(uuid())
    token     String   @unique
    email     String
    role      Role
    expiresAt DateTime

    status          InvitationStatus @default(PENDING)
    organizationId  String
    createdAt       DateTime         @default(now())
    accepted        Boolean          @default(false)
    claimedByUserId String?

    projects InvitationProject[]
}

model InvitationProject {
    id           String @id @default(uuid())
    invitationId String
    projectId    String

    invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
    project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@unique([invitationId, projectId])
}

model Notification {
    id         String                 @id @default(uuid())
    type       NotificationType
    title      String
    body       String?
    actionUrl  String?
    entityType NotificationEntityType
    entityId   String

    orgId        String
    organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

    projectId String?
    project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

    createdAt  DateTime                @default(now())
    recipients NotificationRecipient[]
}

model NotificationRecipient {
    id String @id @default(uuid())

    notificationId String
    notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

    membershipId String
    membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

    isRead Boolean   @default(false)
    readAt DateTime?

    @@unique([notificationId, membershipId])
}