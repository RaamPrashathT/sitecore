datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

enum Role {
    IDLE
    ADMIN
    ENGINEER
    CLIENT
}

enum InvitationStatus {
    PENDING
    ACCEPTED
    REJECTED
}

enum CatalogueCategory {
    MATERIALS
    LABOUR
    EQUIPMENT
    SUBCONTRACTORS
    TRANSPORT
    OVERHEAD
}

enum ProjectStatus {
    DRAFT
    ACTIVE
    COMPLETED
    ARCHIVED
}

enum PhaseStatus {
    PLANNING
    PAYMENT_PENDING
    ACTIVE
    COMPLETED
}

enum RequisitionStatus {
    DRAFT
    PENDING_APPROVAL
    APPROVED
    REJECTED
}

enum RequisitionItemStatus {
    ORDERED
    UNORDERED
}

enum NotificationType {
    REQUISITION_SUBMITTED
    REQUISITION_APPROVED
    REQUISITION_REJECTED
    PHASE_STATUS_CHANGED
    PHASE_PAYMENT_DUE
    SITE_LOG_CREATED
    PROJECT_STATUS_CHANGED
}

enum NotificationEntityType {
    REQUISITION
    PHASE
    SITE_LOG
    PROJECT
}

model Organization {
    id        String   @id @default(uuid())
    name      String
    slug      String   @unique
    slugBase  String
    slugIndex Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    image     String?

    notifications Notification[]
    catalogue     Catalogue[]
    members       Membership[]
    projects      Project[]
}

model Membership {
    id     String @id @default(uuid())
    userId String
    role   Role

    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId String

    siteLogs               SiteLog[]
    images                 Image[]
    comments               Comment[]
    notificationRecipients NotificationRecipient[]

    @@unique([userId, organizationId])
}

model Catalogue {
    id              String            @id @default(uuid())
    name            String
    category        CatalogueCategory
    unit            String
    defaultLeadTime Int               @default(0)

    supplierQuotes SupplierQuote[]

    organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId   String
    requisitionItems RequisitionItem[]

    @@unique([name, organizationId])
}

model SupplierQuote {
    id           String  @id @default(uuid())
    supplier     String
    truePrice    Decimal
    standardRate Decimal
    leadTime     Int?

    catalogue    Catalogue         @relation(fields: [catalogueId], references: [id], onDelete: Cascade)
    catalogueId  String
    assignedItem RequisitionItem[]

    @@unique([catalogueId, supplier])
}

model Project {
    id              String  @id @default(uuid())
    name            String
    slug            String
    slugBase        String
    slugIndex       Int
    address         String
    estimatedBudget Decimal

    status ProjectStatus @default(ACTIVE)

    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId String

    
    assignments   Assignment[]
    phases        Phase[]
    invitations   InvitationProject[]
    notifications Notification[]

    @@unique([slug, organizationId])
}

model Assignment {
    id     String @id @default(uuid())
    userId String
    role   Role

    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId String

    @@unique([userId, projectId])
}

model Phase {
    id              String      @id @default(uuid())
    name            String
    description     String?
    budget          Decimal
    paymentDeadline DateTime
    startDate       DateTime
    isPaid          Boolean     @default(false)
    status          PhaseStatus @default(PLANNING)

    sequenceOrder Decimal @default(1.0)

    projectId String
    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    requisitions Requisition[]
    siteLogs     SiteLog[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([name, projectId])
}

model SiteLog {
    id          String  @id @default(uuid())
    title       String
    description String?

    phaseId String
    phase   Phase  @relation(fields: [phaseId], references: [id], onDelete: Cascade)

    authorId String
    author   Membership @relation(fields: [authorId], references: [id])
    images   Image[]

    workDate  DateTime
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Image {
    id  String @id @default(uuid())
    url String

    uploaderId String
    uploader   Membership @relation(fields: [uploaderId], references: [id])

    siteLogId String
    siteLog   SiteLog @relation(fields: [siteLogId], references: [id], onDelete: Cascade)

    comments Comment[]

    createdAt DateTime @default(now())
}

model Comment {
    id   String @id @default(uuid())
    text String

    authorId String
    author   Membership @relation(fields: [authorId], references: [id])

    imageId String
    image   Image  @relation(fields: [imageId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Requisition {
    id          String            @id @default(uuid())
    status      RequisitionStatus @default(DRAFT)
    phaseId     String
    phase       Phase             @relation(fields: [phaseId], references: [id], onDelete: Cascade)
    requestedBy String
    budget      Decimal

    items     RequisitionItem[]
    createdAt DateTime          @default(now())
    updatedAt DateTime          @updatedAt
}

model RequisitionItem {
    id                String                @id @default(uuid())
    quantity          Decimal
    estimatedUnitCost Decimal
    status            RequisitionItemStatus @default(UNORDERED)

    catalogueId String
    catalogue   Catalogue @relation(fields: [catalogueId], references: [id], onDelete: Cascade)

    assignedSupplierId String?
    assignedSupplier   SupplierQuote? @relation(fields: [assignedSupplierId], references: [id], onDelete: Cascade)

    requisitionId String
    requisition   Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
}

model Invitation {
    id        String   @id @default(uuid())
    token     String   @unique
    email     String
    role      Role
    expiresAt DateTime

    status          InvitationStatus    @default(PENDING)
    organizationId  String
    createdAt       DateTime            @default(now())
    accepted        Boolean             @default(false)
    claimedByUserId String?
    projects        InvitationProject[]
}

model InvitationProject {
    id           String @id @default(uuid())
    invitationId String
    projectId    String

    invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
    project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@unique([invitationId, projectId])
}

model Notification {
    id         String                 @id @default(uuid())
    type       NotificationType
    title      String
    body       String?
    entityType NotificationEntityType
    entityId   String

    organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
    orgId        String

    project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId String?

    createdAt  DateTime                @default(now())
    recipients NotificationRecipient[]
}

model NotificationRecipient {
    id             String       @id @default(uuid())
    
    notificationId String
    notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

    membershipId   String
    membership     Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)
    
    isRead         Boolean      @default(false)
    readAt         DateTime?

    @@unique([notificationId, membershipId])
}
