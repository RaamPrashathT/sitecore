datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

enum Role {
    IDLE
    ADMIN
    ENGINEER
    CLIENT
}

enum InvitationStatus {
    PENDING
    ACCEPTED
    REJECTED
}

enum CatalogueCategory {
    MATERIALS
    LABOUR
    EQUIPMENT
    SUBCONTRACTORS
    TRANSPORT
    OVERHEAD
}

enum ProjectStatus {
    DRAFT
    ACTIVE
    COMPLETED
    ARCHIVED
}

enum PhaseStatus {
    PLANNING
    PAYMENT_PENDING
    ACTIVE
    COMPLETED
}

enum RequisitionStatus {
    DRAFT
    PENDING_APPROVAL
    APPROVED
    REJECTED
}

enum RequisitionItemStatus {
    ORDERED
    UNORDERED
}

enum NotificationType {
    REQUISITION_SUBMITTED
    REQUISITION_APPROVED
    REQUISITION_REJECTED
    PHASE_STATUS_CHANGED
    PHASE_PAYMENT_DUE
    SITE_LOG_CREATED
    PROJECT_STATUS_CHANGED
    PROJECT_INVITATION_ACCEPTED
    PROJECT_INVITATION_REJECTED
    ORGANIZATION_INVITATION_REQUEST
}

enum InventoryLocationType {
    WAREHOUSE
    PROJECT
}

enum InventoryMovementType {
    RECEIPT
    ISSUE
    TRANSFER_IN
    TRANSFER_OUT
    ADJUSTMENT_ADD
    ADJUSTMENT_SUB
    RETURN_IN
    RETURN_OUT
}

enum NotificationEntityType {
    REQUISITION
    PHASE
    SITE_LOG
    PROJECT
    INVITATION
}

model Organization {
    id        String   @id @default(uuid())
    name      String
    slug      String   @unique
    slugBase  String
    slugIndex Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    image     String?

    suppliers          Supplier[]
    notifications      Notification[]
    catalogue          Catalogue[]
    members            Membership[]
    projects           Project[]
    inventoryLocations InventoryLocation[]
    inventoryStocks    InventoryStock[]
    inventoryMovements InventoryMovement[]
}

model Membership {
    id     String @id @default(uuid())
    userId String
    role   Role

    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId String

    siteLogs               SiteLog[]
    images                 Image[]
    comments               Comment[]
    notificationRecipients NotificationRecipient[]
    inventoryMovements     InventoryMovement[]

    @@unique([userId, organizationId])
}

model Catalogue {
    id              String            @id @default(uuid())
    name            String
    category        CatalogueCategory
    unit            String
    defaultLeadTime Int               @default(0)

    supplierQuotes     SupplierQuote[]
    organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId     String
    requisitionItems   RequisitionItem[]
    inventoryStocks    InventoryStock[]
    inventoryMovements InventoryMovement[]

    @@unique([name, organizationId])
}

model Supplier {
    id            String  @id @default(uuid())
    name          String
    email         String?
    phone         String?
    contactPerson String?
    address       String?

    deletedAt DateTime?

    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId String

    quotes SupplierQuote[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([name, organizationId])
}

model SupplierQuote {
    id           String  @id @default(uuid())
    truePrice    Decimal
    standardRate Decimal
    leadTime     Int?
    inventory    Int     @default(0)

    supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
    supplierId String

    catalogue   Catalogue @relation(fields: [catalogueId], references: [id], onDelete: Cascade)
    catalogueId String

    assignedItem RequisitionItem[]
    history      SupplierQuoteHistory[]

    createdAt          DateTime            @default(now())
    updatedAt          DateTime            @updatedAt
    inventoryMovements InventoryMovement[]

    @@unique([catalogueId, supplierId])
}

model SupplierQuoteHistory {
    id              String        @id @default(uuid())
    supplierQuoteId String
    supplierQuote   SupplierQuote @relation(fields: [supplierQuoteId], references: [id], onDelete: Cascade)

    truePrice    Decimal
    standardRate Decimal
    leadTime     Int?
    inventory    Int

    changeReason      String?
    changedByMemberId String?
    changedAt         DateTime @default(now())
}

model InventoryLocation {
    id             String                @id @default(uuid())
    organizationId String
    name           String
    code           String?
    type           InventoryLocationType
    projectId      String?
    isActive       Boolean               @default(true)
    createdAt      DateTime              @default(now())
    updatedAt      DateTime              @updatedAt

    organization Organization @relation(fields: [organizationId], references: [id])
    project      Project?     @relation(fields: [projectId], references: [id])

    stocks        InventoryStock[]
    movementsFrom InventoryMovement[] @relation("InventoryMovementFrom")
    movementsTo   InventoryMovement[] @relation("InventoryMovementTo")

    @@unique([organizationId, name])
    @@unique([organizationId, code])
    @@index([organizationId])
    @@index([projectId])
}

model InventoryStock {
    id               String   @id @default(uuid())
    organizationId   String
    locationId       String
    catalogueId      String
    quantity         Decimal  @default(0) @db.Decimal(18, 3)
    minimumQuantity  Decimal? @db.Decimal(18, 3)
    reservedQuantity Decimal? @db.Decimal(18, 3)
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    organization Organization      @relation(fields: [organizationId], references: [id])
    location     InventoryLocation @relation(fields: [locationId], references: [id])
    catalogue    Catalogue         @relation(fields: [catalogueId], references: [id])

    @@unique([locationId, catalogueId])
    @@index([organizationId])
    @@index([locationId])
    @@index([catalogueId])
}

model InventoryMovement {
    id             String                @id @default(uuid())
    organizationId String
    type           InventoryMovementType
    catalogueId    String
    quantity       Decimal               @db.Decimal(18, 3)

    fromLocationId String?
    toLocationId   String?

    referenceType   String?
    referenceId     String?
    transferGroupId String?
    supplierQuoteId String?
    unitCost        Decimal? @db.Decimal(18, 2)

    remarks           String?
    movementDate      DateTime @default(now())
    createdByMemberId String?
    createdAt         DateTime @default(now())

    organization    Organization       @relation(fields: [organizationId], references: [id])
    catalogue       Catalogue          @relation(fields: [catalogueId], references: [id])
    fromLocation    InventoryLocation? @relation("InventoryMovementFrom", fields: [fromLocationId], references: [id])
    toLocation      InventoryLocation? @relation("InventoryMovementTo", fields: [toLocationId], references: [id])
    supplierQuote   SupplierQuote?     @relation(fields: [supplierQuoteId], references: [id])
    createdByMember Membership?        @relation(fields: [createdByMemberId], references: [id])

    @@index([organizationId, movementDate])
    @@index([catalogueId, movementDate])
    @@index([fromLocationId])
    @@index([toLocationId])
    @@index([supplierQuoteId])
    @@index([transferGroupId])
    @@index([referenceType, referenceId])
}

model Project {
    id              String  @id @default(uuid())
    name            String
    slug            String
    slugBase        String
    slugIndex       Int
    address         String
    estimatedBudget Decimal

    status ProjectStatus @default(ACTIVE)

    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    organizationId String

    assignments        Assignment[]
    phases             Phase[]
    invitations        InvitationProject[]
    notifications      Notification[]
    inventoryLocations InventoryLocation[]

    @@unique([slug, organizationId])
}

model Assignment {
    id     String @id @default(uuid())
    userId String
    role   Role

    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId String

    @@unique([userId, projectId])
}

model Phase {
    id              String      @id @default(uuid())
    name            String
    slug            String
    slugBase        String
    slugIndex       Int
    description     String?
    budget          Decimal
    paymentDeadline DateTime
    startDate       DateTime
    isPaid          Boolean     @default(false)
    status          PhaseStatus @default(PLANNING)

    sequenceOrder Decimal @default(1.0)

    projectId String
    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    requisitions Requisition[]
    siteLogs     SiteLog[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([slug, projectId])
}

model SiteLog {
    id          String  @id @default(uuid())
    title       String
    description String?

    phaseId String
    phase   Phase  @relation(fields: [phaseId], references: [id], onDelete: Cascade)

    authorId String
    author   Membership @relation(fields: [authorId], references: [id])
    images   Image[]
    comments Comment[]

    workDate  DateTime
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Image {
    id  String @id @default(uuid())
    url String

    uploaderId String
    uploader   Membership @relation(fields: [uploaderId], references: [id])

    siteLogId String
    siteLog   SiteLog @relation(fields: [siteLogId], references: [id], onDelete: Cascade)

    comments Comment[]

    createdAt DateTime @default(now())
}

model Comment {
    id   String @id @default(uuid())
    text String

    authorId String
    author   Membership @relation(fields: [authorId], references: [id])

    sitelogId String
    sitelog   SiteLog @relation(fields: [sitelogId], references: [id], onDelete: Cascade)

    imageId String?
    image   Image?  @relation(fields: [imageId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Requisition {
    id          String            @id @default(uuid())
    title       String
    slug        String
    slugBase    String
    slugIndex   Int
    status      RequisitionStatus @default(DRAFT)
    phaseId     String
    phase       Phase             @relation(fields: [phaseId], references: [id], onDelete: Cascade)
    requestedBy String
    budget      Decimal

    items     RequisitionItem[]
    createdAt DateTime          @default(now())
    updatedAt DateTime          @updatedAt

    @@unique([slug, phaseId])
}

model RequisitionItem {
    id                String                @id @default(uuid())
    quantity          Decimal
    estimatedUnitCost Decimal
    status            RequisitionItemStatus @default(UNORDERED)

    catalogueId String
    catalogue   Catalogue @relation(fields: [catalogueId], references: [id], onDelete: Cascade)

    assignedSupplierId String?
    assignedSupplier   SupplierQuote? @relation(fields: [assignedSupplierId], references: [id], onDelete: Cascade)

    requisitionId String
    requisition   Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
}

model Invitation {
    id        String   @id @default(uuid())
    token     String   @unique
    email     String
    role      Role
    expiresAt DateTime

    status          InvitationStatus    @default(PENDING)
    organizationId  String
    createdAt       DateTime            @default(now())
    accepted        Boolean             @default(false)
    claimedByUserId String?
    projects        InvitationProject[]
}

model InvitationProject {
    id           String @id @default(uuid())
    invitationId String
    projectId    String

    invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
    project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@unique([invitationId, projectId])
}

model Notification {
    id    String           @id @default(uuid())
    type  NotificationType
    title String
    body  String?

    actionUrl String?

    entityType NotificationEntityType
    entityId   String

    organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
    orgId        String

    project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId String?

    createdAt  DateTime                @default(now())
    recipients NotificationRecipient[]
}

model NotificationRecipient {
    id String @id @default(uuid())

    notificationId String
    notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

    membershipId String
    membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

    isRead Boolean   @default(false)
    readAt DateTime?

    @@unique([notificationId, membershipId])
}
